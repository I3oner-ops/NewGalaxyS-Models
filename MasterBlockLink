    "# Simple Sequential Fix - One Model at a Time\n",
    "\n",
    "import qai_hub as hub\n",
    "import onnx\n",
    "from onnx import version_converter\n",
    "import onnx_graphsurgeon as gs\n",
    "import onnxsim\n",
    "import numpy as np\n",
    "import time\n",
    "\n",
    "client = hub.Client()\n",
    "device = hub.Device(\"Samsung Galaxy S25 (Family)\")\n",
    "\n",
    "model_mapping = { ... }  # your full dict\n",
    "\n",
    "def process_one(model_id, name):\n",
    "    print(f\"\\n=== Processing {name} ===\")\n",
    "    orig = client.get_model(model_id)\n",
    "    onnx_path = f\"/kaggle/working/{name}.onnx\"\n",
    "    fixed_path = f\"/kaggle/working/{name}_fixed.onnx\"\n",
    "    \n",
    "    orig.download(onnx_path)\n",
    "    \n",
    "    graph = gs.import_onnx(onnx.load(onnx_path))\n",
    "    \n",
    "    for node in graph.nodes:\n",
    "        if node.op == \"Reciprocal\":\n",
    "            one = gs.Constant(\"one\", np.array([1.0], dtype=np.float32))\n",
    "            div = gs.Node(op=\"Div\", inputs=[one, node.inputs[0]], outputs=node.outputs)\n",
    "            graph.replace(node, div)\n",
    "    \n",
    "    graph.cleanup().toposort()\n",
    "    fixed = gs.export_onnx(graph)\n",
    "    \n",
    "    try:\n",
    "        fixed = version_converter.convert_version(fixed, 18)\n",
    "        simp, _ = onnxsim.simplify(fixed)\n",
    "        fixed = simp\n",
    "    except:\n",
    "        pass\n",
    "    \n",
    "    onnx.save(fixed, fixed_path)\n",
    "    \n",
    "    uploaded = client.upload_model(path=fixed_path, name=f\"{name}_fixed\")\n",
    "    print(f\"Uploaded: {uploaded.model_id}\")\n",
    "    \n",
    "    # Clean space\n",
    "    for p in [onnx_path, fixed_path]:\n",
    "        try:\n",
    "            os.remove(p)\n",
    "        except:\n",
    "            pass\n",
    "    \n",
    "    return uploaded.model_id\n",
    "\n",
    "# Example: Process one\n",
    "# process_one(\"mnj3wgvkq\", \"head\")\n",
    "\n",
    "print(\"Define process_one and call it for each model one by one.\")"
   ]
