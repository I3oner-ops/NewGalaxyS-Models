ble_qairt.append(ver)\n        if \"2.42\" in ver:\n            qairt_tag = ver\n\nif not qairt_tag:\n    if available_qairt:\n        available_qairt.sort()\n        qairt_tag = available_qairt[0]\n    else:\n        qairt_tag = \"2.45\"\nprint(f\"✅ Targeting QAIRT SDK Tag: {qairt_tag}\")\n\n# --- MODEL DATA ---\ngood_aux_ids = {\n    \"head\": \"mnj3wgvkq\",\n    \"patch_embed\": \"mm6o8yedm\",\n    \"text_pt2\": \"mqykd7jvn\",\n    \"time\": \"mn1oy6grq\"\n}\n\nraw_qdq_block_ids = [\n    \"mqvd7z9lq\", \"mnl583xeq\", \"mm6o1e54m\", \"mnww2g6rn\", \"mq3o94r3q\", \n    \"mqe65d5vn\", \"mmr9k47rm\", \"mm6o1e95m\", \"mq3o94xkq\", \"mqp2wv6gn\", \n    \"mq3o9pvrq\", \"mmd6k4gvn\", \"mmr9kwywm\", \"mnzz87dxn\", \"mqp2wx9ln\", \n    \"mq2ore90n\", \"mn7od0kvq\", \"mmd6k4x0n\", \"mqvd7voeq\", \"mm6o1yv2m\", \n    \"mqyk9715n\", \"mn4e85k7m\", \"mn1o26jpq\", \"mm5op076q\", \"mqyk978vn\", \n    \"mmr9kyr0m\", \"mqyk97drn\", \"mn7odj94q\", \"mn7od903q\", \"mqyk9povn\", \n    \"mq2or317n\", \"mn1o2g6zq\", \"mn7odvj8q\", \"mm6o1g2dm\", \"mn1o2ggvq\", \n    \"mnj3z7e9q\", \"mngoy5yoq\", \"mqp2w1j0n\", \"mq3oo06rq\", \"mn7oorpjq\"\n]\n\nSTATIC_SHAPES = {\n    \"blocks\": {\n        \"x\": [1, 6240, 5120],\n        \"e\": [1, 6, 5120],\n        \"seq_lens\": [1],\n        \"context\": [1, 257, 5120],\n        \"context_lens\": [1]\n    }\n}\n\ndef download_and_extract(hub_model, out_dir, prefix):\n    raw_path = Path(hub_model.download(str(out_dir / prefix)))\n    if zipfile.is_zipfile(raw_path):\n        extract_dir = out_dir / f\"{prefix}_extracted\"\n        with zipfile.ZipFile(raw_path, \"r\") as zf:\n            zf.extractall(extract_dir)\n        os.remove(raw_path)\n        onnx_files = list(extract_dir.rglob(\"*.onnx\"))\n        return onnx_files[0], extract_dir\n    return raw_path, None\n\ndef make_static_and_infer(model, shapes_dict):\n    graph = gs.import_onnx(model)\n    for inp in graph.inputs:\n        if inp.name in shapes_dict:\n            inp.shape = shapes